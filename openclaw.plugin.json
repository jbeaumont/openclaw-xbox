{
  "id": "openclaw-xbox",
  "name": "Xbox Live",
  "description": "Xbox Live tools via xbl.io — look up profiles, presence, achievements, Game Pass catalog, title history, DVR media, clubs, and active sessions",
  "contracts": {
    "tools": [
      "xbox_my_profile",
      "xbox_search_player",
      "xbox_friends_presence",
      "xbox_player_presence",
      "xbox_player_presence_by_gamertag",
      "xbox_my_achievements",
      "xbox_player_achievements",
      "xbox_gamepass_all",
      "xbox_gamepass_pc",
      "xbox_gamepass_ea_play",
      "xbox_sessions",
      "xbox_session_config",
      "xbox_my_title_history",
      "xbox_player_title_history",
      "xbox_screenshots",
      "xbox_game_clips",
      "xbox_search_clubs",
      "xbox_club_details",
      "xbox_game_details",
      "xbox_add_friend",
      "xbox_remove_friend",
      "xbox_send_message"
    ]
  },
  "toolMetadata": {
    "xbox_my_profile": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_search_player": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_friends_presence": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_player_presence": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_player_presence_by_gamertag": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_my_achievements": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_player_achievements": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_gamepass_all": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_gamepass_pc": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_gamepass_ea_play": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_sessions": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_session_config": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_my_title_history": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_player_title_history": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_screenshots": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_game_clips": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_search_clubs": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_club_details": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_game_details": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey"] }] },
    "xbox_add_friend": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey", "enableWriteTools"] }] },
    "xbox_remove_friend": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey", "enableWriteTools"] }] },
    "xbox_send_message": { "configSignals": [{ "rootPath": "plugins.entries.openclaw-xbox.config", "required": ["apiKey", "enableWriteTools"] }] }
  },
  "skills": ["./skills"],
  "setup": {
    "providers": [
      {
        "id": "xbl-io",
        "authMethods": ["api-key"],
        "envVars": ["OPENCLAW_XBOX_API_KEY"]
      }
    ],
    "requiresRuntime": false
  },
  "activation": {
    "onStartup": false,
    "onCommands": ["xbox"],
    "onConfigPaths": ["plugins.entries.openclaw-xbox.config"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "Your xbl.io API key (X-Authorization header)"
      },
      "enableWriteTools": {
        "type": "boolean",
        "default": false,
        "description": "Opt in to state-changing tools (add/remove friend, send message). These are owner-only and require explicit confirmation."
      }
    }
  }
}
